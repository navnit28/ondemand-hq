# ODA Productivity Suite — environment configuration
# Copy to .env and fill in. The API key is server-side only; it NEVER ships to the browser.

# OnDemand API key (required) — https://app.on-demand.io
ONDEMAND_API_KEY=

# OnDemand API base URL (optional; default shown)
ONDEMAND_BASE_URL=https://api.on-demand.io

# Backend port (optional; default 8080)
PORT=8080

# Stream debug mode (Workstream 1) — ON by default at start.
# When true: every SSE event is logged server-side with ISO timestamp, event type,
# token/char count, and session/conversation id; the frontend debug drawer and the
# frame logs are written to the server console.
# Set to false to disable. (The UI footer also has a live toggle.)
STREAM_DEBUG=true
